# CMIS Configuration

# ========================================
# OpenAI & Anthropic API
# ========================================
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ========================================
# 데이터 API
# ========================================

# DART (전자공시) API
# 발급: https://opendart.fss.or.kr
# 무료, 즉시 발급
DART_API_KEY=your-dart-api-key-here

# KOSIS (통계청) API
# 발급: https://kosis.kr/openapi/index/index.jsp
# 무료, 승인 필요 (1-2일)
KOSIS_API_KEY=your-kosis-api-key-here

# ECOS (한국은행 경제통계) API
# 발급: https://ecos.bok.or.kr/api/
# 무료, 즉시 발급
ECOS_API_KEY=your-ecos-api-key-here

# 한국공공데이터포털 API
# 발급: https://www.data.go.kr/
# 무료, 즉시 발급
DATAGOKR_API_KEY=your-datagokr-api-key-here

# World Bank API
# 인증 불필요 (Public API)
# 문서: https://datahelpdesk.worldbank.org/knowledgebase/articles/889392
# WORLDBANK_API_KEY=not_required

# ========================================
# Google Custom Search (웹 검색)
# ========================================
# API 키: https://console.cloud.google.com/apis/credentials
# Engine ID: https://programmablesearchengine.google.com/
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO
