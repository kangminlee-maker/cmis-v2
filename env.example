# UMIS v9 Configuration

# ========================================
# v1: 기본 설정 (seed 기반만 사용 시)
# ========================================
# v1에서는 외부 API 불필요 (seed YAML만 사용)

# ========================================
# v1+v7: 외부 데이터 연동 (선택적)
# ========================================

# DART API (한국 전자공시)
# 발급: https://opendart.fss.or.kr/
DART_API_KEY=your-dart-api-key-here

# Tavily API (웹 검색)
# 발급: https://tavily.com/
TAVILY_API_KEY=your-tavily-api-key-here

# KOSIS API (통계청)
# 발급: https://kosis.kr/openapi/
KOSIS_API_KEY=your-kosis-api-key-here

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO
