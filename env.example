# UMIS v9 Configuration

# ========================================
# OpenAI & Anthropic API
# ========================================
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ========================================
# 한국 공공 데이터 API
# ========================================

# DART (전자공시) API
# 발급: https://opendart.fss.or.kr
# 무료, 즉시 발급
DART_API_KEY=your-dart-api-key-here

# KOSIS (통계청) API
# 발급: https://kosis.kr/openapi/index/index.jsp
# 무료, 승인 필요 (1-2일)
KOSIS_API_KEY=your-kosis-api-key-here

# ========================================
# Google Custom Search (웹 검색)
# ========================================
# API 키: https://console.cloud.google.com/apis/credentials
# Engine ID: https://programmablesearchengine.google.com/
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO
